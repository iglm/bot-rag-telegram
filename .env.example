# Configuración del Bot RAG Telegram
# Copia este archivo como .env y completa tus credenciales

# Token de BotFather (Telegram)
# Cómo obtenerlo: Abre Telegram, busca @BotFather, escribe /newbot, sigue los pasos
BOT_TOKEN_DOCS=tu_token_aqui

# API Key de OpenRouter
# Cómo obtenerlo: Regístrate en https://openrouter.ai/keys
OPENROUTER_API_KEY=tu_key_aqui

# Modelo LLM (opcional, default: nemotron-3-super-120b-a12b:free)
# Ver modelos gratuitos: https://openrouter.ai/models?fmt=cards&price=free
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
